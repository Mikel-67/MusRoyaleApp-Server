<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="250dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_margin="10dp">

    <LinearLayout
        android:id="@+id/cardMatch"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_magic_parchment"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtMatchTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PARTIDA 2vs2"
            android:textColor="#BB86FC"
            android:textStyle="bold"
            android:textSize="12sp"
            android:fontFamily="serif"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="4dp"
            android:background="#20FFFFFF"> <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgP1"
                android:layout_width="35dp"
                android:layout_height="35dp"
                app:shapeAppearanceOverlay="@style/CircleAppearance"
                android:src="@android:drawable/ic_menu_gallery"/>
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgP2"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginStart="-10dp"
                app:shapeAppearanceOverlay="@style/CircleAppearance"
                android:src="@android:drawable/ic_menu_gallery"/>
        </LinearLayout>

            <TextView
                android:id="@+id/txtTeam1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equipo A"
                android:textColor="#FFFFFF"
                android:layout_marginStart="10dp"
                android:textStyle="bold"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#40FFFFFF"
            android:layout_marginVertical="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="4dp"
            android:background="#20FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgP3"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    app:shapeAppearanceOverlay="@style/CircleAppearance"
                    android:src="@android:drawable/ic_menu_gallery"/>
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgP4"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_marginStart="-10dp"
                    app:shapeAppearanceOverlay="@style/CircleAppearance"
                    android:src="@android:drawable/ic_menu_gallery"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtTeam2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equipo B"
                android:textColor="#FFFFFF"
                android:layout_marginStart="10dp"
                android:textStyle="bold"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="20dp"
        android:layout_height="3dp"
        android:background="#7E57C2"/>
</LinearLayout>