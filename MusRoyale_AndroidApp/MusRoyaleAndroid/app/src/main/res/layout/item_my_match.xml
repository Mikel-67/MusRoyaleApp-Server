<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_magic_parchment"
    android:layout_margin="16dp">

    <TextView
        android:id="@+id/txtRoundTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CUARTOS"
        android:textColor="#BB86FC"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.imageview.ShapeableImageView android:id="@+id/imgP1" android:layout_width="50dp" android:layout_height="50dp" app:shapeAppearanceOverlay="@style/CircleAppearance" android:src="@android:drawable/ic_menu_gallery"/>
                <com.google.android.material.imageview.ShapeableImageView android:id="@+id/imgP2" android:layout_width="50dp" android:layout_height="50dp" android:layout_marginStart="-15dp" app:shapeAppearanceOverlay="@style/CircleAppearance" android:src="@android:drawable/ic_menu_gallery"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtTeam1Names"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jugador 1 &amp; 2"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:gravity="center"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textColor="#BB86FC"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.imageview.ShapeableImageView android:id="@+id/imgP3" android:layout_width="50dp" android:layout_height="50dp" app:shapeAppearanceOverlay="@style/CircleAppearance" android:src="@android:drawable/ic_menu_gallery"/>
                <com.google.android.material.imageview.ShapeableImageView android:id="@+id/imgP4" android:layout_width="50dp" android:layout_height="50dp" android:layout_marginStart="-15dp" app:shapeAppearanceOverlay="@style/CircleAppearance" android:src="@android:drawable/ic_menu_gallery"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtTeam2Names"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jugador 3 &amp; 4"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>